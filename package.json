{
  "name": "@code-sherpas/pharos-react",
  "version": "0.19.0",
  "description": "React component library for Code Sherpas. Consumes @code-sherpas/pharos-tokens. Vite library mode + CSS Modules — no Tailwind, no CSS framework required at the consumer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-sherpas/pharos-react.git"
  },
  "homepage": "https://github.com/code-sherpas/pharos-react#readme",
  "bugs": {
    "url": "https://github.com/code-sherpas/pharos-react/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "files": [
    "dist",
    "RULES.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./Avatar": {
      "types": "./dist/components/Avatar.d.ts",
      "import": "./dist/components/Avatar.js"
    },
    "./Badge": {
      "types": "./dist/components/Badge.d.ts",
      "import": "./dist/components/Badge.js"
    },
    "./Button": {
      "types": "./dist/components/Button.d.ts",
      "import": "./dist/components/Button.js"
    },
    "./Card": {
      "types": "./dist/components/Card.d.ts",
      "import": "./dist/components/Card.js"
    },
    "./Checkbox": {
      "types": "./dist/components/Checkbox.d.ts",
      "import": "./dist/components/Checkbox.js"
    },
    "./Combobox": {
      "types": "./dist/components/Combobox.d.ts",
      "import": "./dist/components/Combobox.js"
    },
    "./Dialog": {
      "types": "./dist/components/Dialog.d.ts",
      "import": "./dist/components/Dialog.js"
    },
    "./DropdownMenu": {
      "types": "./dist/components/DropdownMenu.d.ts",
      "import": "./dist/components/DropdownMenu.js"
    },
    "./IconButton": {
      "types": "./dist/components/IconButton.d.ts",
      "import": "./dist/components/IconButton.js"
    },
    "./Input": {
      "types": "./dist/components/Input.d.ts",
      "import": "./dist/components/Input.js"
    },
    "./Popover": {
      "types": "./dist/components/Popover.d.ts",
      "import": "./dist/components/Popover.js"
    },
    "./RadioGroup": {
      "types": "./dist/components/RadioGroup.d.ts",
      "import": "./dist/components/RadioGroup.js"
    },
    "./Select": {
      "types": "./dist/components/Select.d.ts",
      "import": "./dist/components/Select.js"
    },
    "./Separator": {
      "types": "./dist/components/Separator.d.ts",
      "import": "./dist/components/Separator.js"
    },
    "./Sheet": {
      "types": "./dist/components/Sheet.d.ts",
      "import": "./dist/components/Sheet.js"
    },
    "./Spinner": {
      "types": "./dist/components/Spinner.d.ts",
      "import": "./dist/components/Spinner.js"
    },
    "./Switch": {
      "types": "./dist/components/Switch.d.ts",
      "import": "./dist/components/Switch.js"
    },
    "./Textarea": {
      "types": "./dist/components/Textarea.d.ts",
      "import": "./dist/components/Textarea.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "scripts": {
    "build": "vite build && pnpm verify:dist-types && pnpm verify:dist-rsc",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:e2e": "pnpm --filter @examples/saas-demo test:e2e",
    "dev:demo": "pnpm --filter @examples/saas-demo dev",
    "typecheck": "tsc --noEmit",
    "verify:dist-types": "tsc --noEmit -p tsconfig.dist-smoke.json",
    "verify:dist-rsc": "node scripts/verify-dist-rsc.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build",
    "prepare": "husky && bash scripts/snapshot-pharos-tokens.sh"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,mdx,css,yml,yaml}": "prettier --write"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "@code-sherpas/pharos-tokens": "^0.4.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@changesets/cli": "^2.27.10",
    "@code-sherpas/pharos-tokens": "^0.4.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.10",
    "chromatic": "^17.4.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.7",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
