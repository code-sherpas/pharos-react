engine-strict=true
# pnpm-specific options below. npm CLI warns about them as "Unknown project config"
# but pnpm reads them correctly; keep them here because pnpm has no separate .pnpmrc.
# Feel free to ignore the warnings in CI output.
minimum-release-age=7
# Own-org packages are published by us — the 7-day supply-chain guard does not
# apply. Skip the wait for any `@code-sherpas/*` package so we can consume a
# fresh release of pharos-tokens (or future org packages) the same day it ships.
minimum-release-age-exclude[]=@code-sherpas/pharos-tokens
minimum-release-age-exclude[]=@code-sherpas/pharos-react
strict-peer-dependencies=false
auto-install-peers=true
